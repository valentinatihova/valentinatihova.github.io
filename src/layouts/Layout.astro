---
import '../index.css';
import SiteNav from '../components/layout/SiteNav';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  jsonLd?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description = 'Valentina Tihova—Senior Data & MarTech engineer. Pipelines, decisioning, reporting, martech, and analytics—case studies and short notes from real projects.',
  canonical,
  ogImage = 'https://valentinatihova.com/og-image.png',
  ogImageAlt = 'Valentina Tihova — Senior Data & MarTech Engineer',
  ogType = 'website',
  jsonLd,
  noindex = false,
} = Astro.props;

const canonicalUrl = canonical ?? Astro.url.href.replace(/\/$/, '');
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-B0SWXJDJW3"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-B0SWXJDJW3');
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Valentina Tihova" />
    <meta name="theme-color" content="#FFFFFF" />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow" />
    }
    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Valentina Tihova" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300..800;1,6..72,300..800&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&display=swap"
      rel="stylesheet"
    />
    <!-- JSON-LD structured data -->
    {jsonLdArray.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <!-- Sitewide Person + WebSite schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Valentina Tihova",
      "jobTitle": "Senior Data & MarTech Engineer",
      "url": "https://valentinatihova.com",
      "sameAs": [
        "https://www.linkedin.com/in/valentina-tihova/",
        "https://github.com/valentinatihova"
      ]
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Valentina Tihova",
      "url": "https://valentinatihova.com",
      "description": "Case studies and notes on data engineering, MarTech, analytics, and reporting from production work."
    }
    </script>
  </head>
  <body class="bg-white text-stone-900 antialiased font-serif">
    <SiteNav client:load />
    <slot />
    <footer class="mt-32 border-t border-stone-200 bg-white">
      <div class="container mx-auto px-4 py-8 sm:py-6">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
          <!-- Left: brand + copy -->
          <div class="flex items-center gap-6">
            <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-stone-400">
              © {new Date().getFullYear()} Valentina Tihova
            </p>
            <span class="h-px w-6 bg-stone-200 hidden sm:block" />
            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-stone-300 hidden sm:block">
              Valencia, Spain
            </p>
          </div>
          <!-- Right: contact links -->
          <div class="flex items-center gap-5">
            <a
              href="mailto:valentina.tikhova1@gmail.com"
              class="font-mono text-[10px] uppercase tracking-[0.18em] text-stone-400 transition-colors hover:text-stone-900 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
            >
              Email
            </a>
            <a
              href="https://www.linkedin.com/in/valentina-tihova/"
              target="_blank"
              rel="noreferrer"
              class="font-mono text-[10px] uppercase tracking-[0.18em] text-stone-400 transition-colors hover:text-stone-900 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
            >
              LinkedIn
            </a>
            <a
              href="https://github.com/valentinatihova"
              target="_blank"
              rel="noreferrer"
              class="font-mono text-[10px] uppercase tracking-[0.18em] text-stone-400 transition-colors hover:text-stone-900 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
            >
              GitHub
            </a>
          </div>
        </div>
      </div>
    </footer>
    <!-- Cloudflare Web Analytics -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "d17c303955fe40668112c368f715f162"}'></script>
  </body>
</html>
