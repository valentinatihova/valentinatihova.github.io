---
import Layout from '../../layouts/Layout.astro';
import { ArticleBody } from '../../components/article/ArticleBody';
import { articles, ARTICLE_KIND_LABEL, getArticleKind } from '../../data/articles';
import { ArrowLeft, Calendar, Clock } from 'lucide-react';

const SITE_URL = 'https://valentinatihova.com';

export async function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;

const kind = getArticleKind(article);
const kindLabel = ARTICLE_KIND_LABEL[kind];
const articleUrl = `${SITE_URL}/article/${article.id}`;
const ogImage = `${SITE_URL}/og/${article.id}.png`;

const formattedDate = new Date(article.date).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.summary,
  url: articleUrl,
  datePublished: article.date,
  dateModified: article.date,
  author: {
    '@type': 'Person',
    name: 'Valentina Tihova',
    url: SITE_URL,
    sameAs: [
      'https://www.linkedin.com/in/valentina-tihova/',
      'https://github.com/valentinatihova',
    ],
  },
  publisher: {
    '@type': 'Person',
    name: 'Valentina Tihova',
    url: SITE_URL,
  },
  image: ogImage,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
};

const GithubIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3-.3 6-1.5 6-6.5a5.4 5.4 0 0 0-1.5-3.8 5.3 5.3 0 0 0-.1-3.8s-1.2-.4-3.9 1.4a13.3 13.3 0 0 0-7 0C6.2 1.5 5 1.9 5 1.9a5.3 5.3 0 0 0-.1 3.8 5.4 5.4 0 0 0-1.5 3.8c0 5 3 6.2 6 6.5a4.8 4.8 0 0 0-1 3.2v4"/></svg>`;
---

<Layout
  title={`${article.title} | Valentina Tihova, Data & MarTech Engineer`}
  description={article.summary}
  canonical={articleUrl}
  ogImage={ogImage}
  ogImageAlt={article.title}
  ogType="article"
  jsonLd={articleJsonLd}
>
  <article class="container mx-auto px-4 py-12 md:py-20">
    <div class="mx-auto grid max-w-6xl gap-12 xl:grid-cols-[minmax(0,1fr)_240px]">
      <div class="min-w-0">
        <a
          href="/"
          class="mb-12 inline-flex items-center gap-2 text-sm font-medium font-mono text-stone-400 transition-colors hover:text-stone-100"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Back to Articles
        </a>

        <!-- Static article header — fully indexed by search crawlers -->
        <header class="mb-12 max-w-3xl">
          <div class="mb-8 flex items-center gap-4">
            <span class="font-mono text-[11px] font-medium uppercase tracking-[0.32em] text-accent">
              {kindLabel}
            </span>
            <span class="h-px w-16 bg-accent/40"></span>
          </div>

          <div class="mb-6 flex flex-wrap gap-x-3 gap-y-1 font-mono text-[12px] uppercase tracking-[0.18em] text-stone-400">
            {article.tags.map((tag, i) => (
              <span>
                {tag}
                {i < article.tags.length - 1 ? <span class="ml-3 text-stone-700">/</span> : null}
              </span>
            ))}
          </div>

          <h1 class="mb-8 font-serif text-4xl font-bold leading-tight tracking-tight text-stone-50 md:text-5xl lg:text-6xl">
            {article.title}
          </h1>

          <div class="mb-10 flex flex-wrap items-center gap-6 border-b border-stone-700 pb-10 text-sm font-mono text-stone-400">
            <span class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
              {formattedDate}
            </span>
            <span class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {article.readTime}
            </span>
            {article.githubUrl && (
              <a
                href={article.githubUrl}
                target="_blank"
                rel="noreferrer"
                class="ml-auto flex items-center gap-2 text-stone-300 transition-colors hover:text-accent"
              >
                <Fragment set:html={GithubIcon} />
                View Source Code
              </a>
            )}
          </div>

          {article.caseStudyFrame && (
            <div class="not-prose mb-14 grid gap-8 border-y border-stone-800 py-8 md:grid-cols-3 md:gap-0">
              <div class="md:px-8 md:first:pl-0">
                <p class="font-mono text-[11px] font-medium uppercase tracking-[0.28em] text-accent">My role</p>
                <p class="mt-3 font-serif text-[0.98rem] leading-[1.6] text-stone-200">{article.caseStudyFrame.role}</p>
              </div>
              <div class="md:border-l md:border-stone-800 md:px-8">
                <p class="font-mono text-[11px] font-medium uppercase tracking-[0.28em] text-accent">Scope</p>
                <p class="mt-3 font-serif text-[0.98rem] leading-[1.6] text-stone-200">{article.caseStudyFrame.scope}</p>
              </div>
              <div class="md:border-l md:border-stone-800 md:px-8 md:last:pr-0">
                <p class="font-mono text-[11px] font-medium uppercase tracking-[0.28em] text-accent">Why it matters</p>
                <p class="mt-3 font-serif text-[0.98rem] leading-[1.6] text-stone-200">{article.caseStudyFrame.outcome}</p>
              </div>
            </div>
          )}
        </header>

        <!-- Client-hydrated article body: MDX content + D3 charts + interactions -->
        <ArticleBody client:only="react" articleId={article.id} articleSummary={article.summary} />
      </div>

      <!-- TOC is part of ArticleBody (client island) so it can scroll-spy -->
    </div>
  </article>
</Layout>
